# ═══════════════════════════════════════════════════════════════
# Abstrack — Variables d'environnement
# Copier vers .env et remplir toutes les valeurs requises.
# Ne jamais committer .env dans git.
# ═══════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────
# En local (docker compose) : utiliser les valeurs ci-dessous.
# En prod (Railway) : copier l'URL depuis le plugin PostgreSQL.
DATABASE_URL=postgresql://abstrack:changeme@localhost:5432/abstrack
POSTGRES_PASSWORD=changeme

# ─── Blockchain ───────────────────────────────────────────────
# Nœud Abstract — Chainstack, Alchemy ou nœud propre.
# Créer un compte sur https://chainstack.com (plan gratuit suffisant pour MVP).
ABSTRACT_RPC_WSS=wss://your-abstract-node/ws
ABSTRACT_RPC_HTTP=https://your-abstract-node
ABSTRACT_CHAIN_ID=2741

# ─── Backend ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Générer avec : openssl rand -hex 32
JWT_SECRET=change-me-min-32-chars-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Générer avec : openssl rand -hex 32
# Utilisé pour les routes /admin/* — ne pas partager
ADMIN_SECRET=change-me-min-32-chars-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL du frontend (pour CORS)
# En prod : https://abstrack.vercel.app (ou ton domaine)
CORS_ORIGIN=http://localhost:3000

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
# Indexer : LOG_FORMAT=json (prod) | LOG_FORMAT=text (dev)
LOG_FORMAT=json

# ─── Alpha Feed (seuils configurables) ────────────────────────
ALPHA_WHALE_ETH=5
ALPHA_BURST_SALES=10

# ─── Frontend (Next.js — public, dans le build) ───────────────
# En local : http://localhost:3001
# En prod  : https://ton-backend.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
NEXT_PUBLIC_CHAIN_ID=2741
